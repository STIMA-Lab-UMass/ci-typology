# Copy this file to the repository root as `.env` and fill in your own values.
# Every variable below is read by the pipeline via os.environ.

# Absolute path to the cloned repository root (added to sys.path).
PROJECT_ROOT=<project root>
# Absolute path where input data (GADM_global, building tiles, etc.) lives.
PROJECT_DATA=<project data>
# Absolute path where pipeline outputs are written.
PROJECT_OUT=<project out>
# Absolute path for run/progress metadata caches.
PROJECT_CACHE_METADATA=<project cache metadata>
# OpenAI API key used for NAICS classification (note the non-standard name).
OPEN_AI_API_KEY=<openai api key>
